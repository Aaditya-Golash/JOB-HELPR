# Required for save_application / list_applications to persist data.
# Create a Vercel Blob store (Storage tab in the Vercel dashboard) and
# connect it to this project -- BLOB_READ_WRITE_TOKEN is then set
# automatically for Vercel deployments. For local dev, copy the value from
# the Vercel dashboard's Environment Variables page into a local .env file.
BLOB_READ_WRITE_TOKEN=

# Optional. Populate generate_resume / generate_cover_letter's contact line
# with real values -- left unset, they fall back to an obvious placeholder
# instead of failing, since this repo is public and these three (unlike the
# public-by-design linkedin/github in lib/profile.ts) aren't meant to be
# committed in plaintext. Set these in the Vercel dashboard for a real
# deployment.
CONTACT_EMAIL=
CONTACT_PHONE=
CONTACT_LOCATION=

# Optional. Region-matched mailing addresses for get_mailing_address, used
# only to fill an actual "mailing address" field on a real ATS application
# form -- never included in generate_resume / generate_cover_letter output.
# A street address is more identifying than phone/email, so these have no
# placeholder fallback in lib/address.ts -- an unset or unmatched region
# just returns null rather than guessing. See lib/address.ts for the
# city/province keywords each one matches. Recommend marking these
# "Sensitive" in the Vercel dashboard (unlike CONTACT_*, nothing here needs
# a local `vercel env pull` round-trip once set).
ADDRESS_VANCOUVER=
ADDRESS_CALGARY=
ADDRESS_EDMONTON=
ADDRESS_TORONTO=
ADDRESS_KELOWNA=
